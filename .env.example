# Sahara configuration via environment variables
# Copy this file to .env and fill in your values.
# Values here override nothing in config.toml — they supplement it.

# ============================================================================
# LLM — OpenAI (ChatGPT)
# ============================================================================
# Optional. Setting the key alone does not select OpenAI. Enable it with:
# sahara config set answer_provider openai
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Optional one-shell model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# LLM — Ollama (local, offline)
# ============================================================================
# Optional. Enable it with:
# sahara config set answer_provider ollama
# Default is http://localhost:11434 — only set this if Ollama runs elsewhere.
# OLLAMA_URL=http://localhost:11434
# Save a non-default model with: sahara config set answer_model MODEL_NAME

# ============================================================================
# Encryption
# ============================================================================
# Passphrase for at-rest encryption of synced files.
# Can also be set with `sahara init` (stored in system keyring).
# SAHARA_PASSPHRASE=your_passphrase_here
