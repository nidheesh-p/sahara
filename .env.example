# Sahara configuration via environment variables
# Copy this file to .env and fill in your values.
# Values here override nothing in config.toml — they supplement it.

# ============================================================================
# LLM — OpenAI (ChatGPT)
# ============================================================================
# When set, `sahara ask` automatically uses OpenAI instead of Ollama.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# LLM — Ollama (local, offline)
# ============================================================================
# Only used when OPENAI_API_KEY is not set (or --provider ollama is passed).
# Default is http://localhost:11434 — only set this if Ollama runs elsewhere.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ============================================================================
# Encryption
# ============================================================================
# Passphrase for at-rest encryption of synced files.
# Can also be set with `sahara init` (stored in system keyring).
# SAHARA_PASSPHRASE=your_passphrase_here
